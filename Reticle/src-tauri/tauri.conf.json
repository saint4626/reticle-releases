{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Reticle",
  "version": "1.1.6",
  "identifier": "com.reticle.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Reticle",
        "width": 1280,
        "height": 800,
        "minWidth": 1280,
        "minHeight": 750,
        "visible": true,
        "transparent": true,
        "devtools": false,
        "decorations": false
      },
      {
        "label": "overlay",
        "title": "Reticle Overlay",
        "width": 200,
        "height": 200,
        "minWidth": 1,
        "minHeight": 1,
        "visible": false,
        "transparent": true,
        "decorations": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "resizable": false,
        "shadow": false
      },
      {
        "label": "capture_toolbar",
        "title": "Reticle Capture",
        "url": "/",
        "width": 800,
        "height": 80,
        "visible": false,
        "transparent": true,
        "decorations": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "resizable": false,
        "shadow": false
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "scope": [
          "**"
        ]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "copyright": "Copyright © 2026 Reticle",
    "shortDescription": "The precision screenshot tool for Windows",
    "externalBin": [
      "binaries/ffmpeg"
    ],
    "resources": [
      "resources/ocr/ppocrv5/*"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "publisher": "Reticle Inc.",
    "licenseFile": "license.txt",
    "windows": {
      "nsis": {
        "installerIcon": "icons/icon.ico",
        "sidebarImage": "icons/sidebar.bmp",
        "displayLanguageSelector": true,
        "languages": [
          "English",
          "Russian"
        ]
      }
    }
  }
}
